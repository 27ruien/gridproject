{
  "name": "gridproject-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "prisma:migrate:deploy": "node ../scripts/check-dev-db-safety.mjs && prisma migrate deploy --schema ../prisma/schema.prisma",
    "prisma:migrate:status": "node ../scripts/check-dev-db-safety.mjs && prisma migrate status --schema ../prisma/schema.prisma",
    "prisma:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "hash-wasm": "^4.12.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
