DATABASE_URL="postgresql://gridproject_app:replace-me@127.0.0.1:5432/gridproject_dev?schema=public"
HOST="127.0.0.1"
PORT="3000"
NODE_ENV="development"
SESSION_SECRET="replace-with-a-long-random-string"
