{
  "name": "kiviflow-project-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://gridproject_app@127.0.0.1:5432/gridproject_dev?schema=public} prisma validate",
    "db:safety:dev": "node scripts/check-dev-db-safety.mjs",
    "db:migrate:deploy:dev": "npm run db:safety:dev && pnpm --dir server exec prisma migrate deploy --schema ../prisma/schema.prisma",
    "db:migrate:status:safe": "npm run db:safety:dev && pnpm --dir server exec prisma migrate status --schema ../prisma/schema.prisma",
    "frontend:lint": "node scripts/frontend-lint.mjs",
    "security:check-tracked-secrets": "node scripts/check-no-tracked-secrets.mjs",
    "release:check": "node scripts/release-check.mjs",
    "lint": "npm run frontend:lint && npm run db:validate && npm run server:lint",
    "server:install": "pnpm --dir server install",
    "server:dev": "pnpm --dir server run dev",
    "server:build": "pnpm --dir server run build",
    "server:start": "pnpm --dir server run start",
    "server:lint": "pnpm --dir server run lint",
    "server:test": "pnpm --dir server run test",
    "server:prisma:generate": "pnpm --dir server run prisma:generate",
    "server:prisma:migrate:deploy": "npm run db:migrate:deploy:dev",
    "server:prisma:seed": "pnpm --dir server run prisma:seed",
    "test": "node tests/domain.test.js && node tests/access-cost.test.js && node tests/api-mode-source.test.js",
    "test:visual": "playwright test -c playwright.config.js",
    "test:visual:update": "playwright test -c playwright.config.js --update-snapshots",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "hash-wasm": "^4.12.0",
    "vite": "^7.1.12",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^6.19.3",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3"
  }
}
