{
  "name": "kiviflow-project-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://gridproject_app@127.0.0.1:5432/gridproject_dev?schema=public} prisma validate",
    "test": "node tests/domain.test.js && node tests/access-cost.test.js",
    "test:visual": "playwright test -c playwright.config.js",
    "test:visual:update": "playwright test -c playwright.config.js --update-snapshots",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "vite": "^7.1.12",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^6.19.3",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3"
  }
}
