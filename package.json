{
  "name": "kiviflow-project-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://gridproject_app@127.0.0.1:5432/gridproject_dev?schema=public} prisma validate",
    "db:safety:dev": "node scripts/check-dev-db-safety.mjs",
    "db:migrate:deploy:dev": "npm run db:safety:dev && bash scripts/run-pnpm.sh --dir server exec prisma migrate deploy --schema ../prisma/schema.prisma",
    "db:migrate:status:safe": "node scripts/check-migration-status.mjs",
    "frontend:lint": "node scripts/frontend-lint.mjs",
    "security:check-tracked-secrets": "node scripts/check-no-tracked-secrets.mjs",
    "test:deployment": "bash scripts/test-deployment-automation.sh",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "release:check": "npm run release:check:server",
    "release:check:ci": "node scripts/release-check.mjs ci",
    "release:check:server": "node scripts/release-check.mjs server",
    "lint": "npm run frontend:lint && npm run db:validate && npm run server:lint",
    "server:install": "bash scripts/run-pnpm.sh --dir server install",
    "server:dev": "bash scripts/run-pnpm.sh --dir server run dev",
    "server:build": "bash scripts/run-pnpm.sh --dir server run build",
    "server:start": "bash scripts/run-pnpm.sh --dir server run start",
    "server:lint": "bash scripts/run-pnpm.sh --dir server run lint",
    "server:test": "bash scripts/run-pnpm.sh --dir server run test",
    "server:prisma:generate": "bash scripts/run-pnpm.sh --dir server run prisma:generate",
    "server:prisma:migrate:deploy": "npm run db:migrate:deploy:dev",
    "server:prisma:seed": "bash scripts/run-pnpm.sh --dir server run prisma:seed",
    "test": "node tests/domain.test.js && node tests/timeline-import.test.js && node tests/access-cost.test.js && node tests/api-mode-source.test.js",
    "test:visual": "playwright test -c playwright.config.js",
    "test:visual:update": "playwright test -c playwright.config.js --update-snapshots",
    "capture:plane-r1": "node scripts/capture-plane-r1.mjs",
    "capture:plane-r1-revision": "node scripts/capture-plane-r1-revision.mjs",
    "capture:plane-r2": "node scripts/capture-plane-r2.mjs",
    "capture:plane-r2-1": "node scripts/capture-plane-r2-1.mjs",
    "capture:plane-r3": "node scripts/capture-plane-r3.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "hash-wasm": "^4.12.0",
    "vite": "^7.1.12",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^6.19.3",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3"
  }
}
