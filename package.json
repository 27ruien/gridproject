{
  "name": "kiviflow-project-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://gridproject_app@127.0.0.1:5432/gridproject_dev?schema=public} prisma validate",
    "db:safety:dev": "node scripts/check-dev-db-safety.mjs",
    "db:migrate:deploy:dev": "npm run db:safety:dev && bash scripts/run-pnpm.sh --dir server exec prisma migrate deploy --schema ../prisma/schema.prisma",
    "db:migrate:status:safe": "node scripts/check-migration-status.mjs",
    "frontend:lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json",
    "test:unit": "vitest run",
    "security:check-tracked-secrets": "node scripts/check-no-tracked-secrets.mjs",
    "test:deployment": "bash scripts/test-deployment-automation.sh",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "release:check": "npm run release:check:server",
    "release:check:ci": "node scripts/release-check.mjs ci",
    "release:check:server": "node scripts/release-check.mjs server",
    "lint": "npm run frontend:lint && npm run db:validate && npm run server:lint",
    "server:install": "bash scripts/run-pnpm.sh --dir server install",
    "server:dev": "bash scripts/run-pnpm.sh --dir server run dev",
    "server:build": "bash scripts/run-pnpm.sh --dir server run build",
    "server:start": "bash scripts/run-pnpm.sh --dir server run start",
    "server:lint": "bash scripts/run-pnpm.sh --dir server run lint",
    "server:test": "bash scripts/run-pnpm.sh --dir server run test",
    "server:prisma:generate": "bash scripts/run-pnpm.sh --dir server run prisma:generate",
    "server:prisma:migrate:deploy": "npm run db:migrate:deploy:dev",
    "server:prisma:seed": "bash scripts/run-pnpm.sh --dir server run prisma:seed",
    "test": "npm run test:unit && node tests/domain.test.js && node tests/timeline-import.test.js && node tests/access-cost.test.js && node tests/path-config.test.js && node tests/preferences.test.js && node tests/api-mode-source.test.js",
    "test:visual": "playwright test -c playwright.config.js",
    "test:visual:update": "playwright test -c playwright.config.js --update-snapshots",
    "capture:react-rewrite": "node scripts/capture-react-rewrite.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.1.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^6.19.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "shadcn": "^4.12.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
