generator client {
  provider = "prisma-client-js"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  ADMIN
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectMemberStatus {
  ACTIVE
  INACTIVE
}

enum ProjectMemberRole {
  MANAGER
  MEMBER
  VIEWER
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum CostRecordStatus {
  ACTIVE
  ARCHIVED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  settings  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  users              User[]
  projects           Project[]
  projectMembers     ProjectMember[]
  milestones         Milestone[]
  timeEntries        TimeEntry[]
  projectCostRecords ProjectCostRecord[]
  sessions           Session[]
  auditLogs          AuditLog[]

  @@map("organizations")
}

model User {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  email          String
  passwordHash   String
  preferences    Json?
  role           OrganizationRole @default(MEMBER)
  status         UserStatus       @default(ACTIVE)
  lastLoginAt    DateTime?        @db.Timestamptz(3)
  deletedAt      DateTime?        @db.Timestamptz(3)
  deletedById    String?
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)

  organization       Organization        @relation(fields: [organizationId], references: [id])
  deletedBy          User?               @relation("UserDeletedBy", fields: [deletedById], references: [id])
  deletedUsers       User[]              @relation("UserDeletedBy")
  ownedProjects      Project[]           @relation("ProjectOwner")
  createdProjects    Project[]           @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  timeEntries        TimeEntry[]
  createdCostRecords ProjectCostRecord[] @relation("CostRecordCreator")
  updatedCostRecords ProjectCostRecord[] @relation("CostRecordUpdater")
  deletedCostRecords ProjectCostRecord[] @relation("CostRecordDeleter")
  auditLogs          AuditLog[]
  sessions           Session[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([organizationId, role])
  @@map("users")
}

model Project {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  description    String?
  status         String
  health         Int       @default(90)
  startDate      DateTime? @db.Date
  dueDate        DateTime? @db.Date
  testDate       DateTime? @db.Date
  acceptanceDate DateTime? @db.Date
  releaseDate    DateTime? @db.Date
  config         Json?
  ownerId        String
  createdById    String
  deletedAt      DateTime? @db.Timestamptz(3)
  deletedById    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  organization Organization        @relation(fields: [organizationId], references: [id])
  owner        User                @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdBy    User                @relation("ProjectCreator", fields: [createdById], references: [id])
  members      ProjectMember[]
  milestones   Milestone[]
  issues       Issue[]
  timeEntries  TimeEntry[]
  costRecord   ProjectCostRecord?

  @@unique([organizationId, code])
  @@index([organizationId, deletedAt])
  @@index([ownerId])
  @@map("projects")
}

model ProjectMember {
  id             String              @id @default(cuid())
  organizationId String
  projectId      String
  userId         String
  status         ProjectMemberStatus @default(ACTIVE)
  role           ProjectMemberRole   @default(MEMBER)
  joinedAt       DateTime            @default(now()) @db.Timestamptz(3)
  createdAt      DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime            @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([organizationId, status])
  @@index([organizationId, role])
  @@map("project_members")
}

model Milestone {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  window         String?
  focus          String?
  status         String
  dueDate        DateTime? @db.Date
  completedAt    DateTime? @db.Timestamptz(3)
  deletedAt      DateTime? @db.Timestamptz(3)
  deletedById    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])

  @@index([organizationId, projectId, deletedAt])
  @@map("milestones")
}

model Issue {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  code           String
  title          String
  type           String
  status         String
  ownerId        String?
  creatorId      String?
  priority       String?
  startDate      DateTime? @db.Date
  dueDate        DateTime? @db.Date
  estimatedHours Decimal?  @db.Decimal(10, 2)
  actualHours    Decimal?  @db.Decimal(10, 2)
  next           String?
  description    String?
  scheduleData   Json?
  deletedAt      DateTime? @db.Timestamptz(3)
  deletedById    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  project      Project         @relation(fields: [projectId], references: [id])
  timeEntries  TimeEntry[]
  comments     IssueComment[]
  activities   IssueActivity[]

  @@unique([projectId, code])
  @@index([organizationId, projectId])
  @@map("issues")
}

model IssueComment {
  id             String    @id @default(cuid())
  organizationId String
  issueId        String
  authorId       String
  text           String
  deletedAt      DateTime? @db.Timestamptz(3)
  deletedById    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  issue Issue @relation(fields: [issueId], references: [id])

  @@index([organizationId, issueId, deletedAt])
  @@index([authorId, createdAt])
  @@map("issue_comments")
}

model IssueActivity {
  id             String   @id @default(cuid())
  organizationId String
  issueId        String
  actorId        String?
  type           String
  text           String
  data           Json?
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  issue Issue @relation(fields: [issueId], references: [id])

  @@index([organizationId, issueId, createdAt])
  @@index([actorId, createdAt])
  @@map("issue_activities")
}

model TimeEntry {
  id               String          @id @default(cuid())
  organizationId   String
  projectId        String
  issueId          String?
  userId           String
  reporterId       String
  workDate         DateTime        @db.Date
  hours            Decimal         @db.Decimal(10, 2)
  status           TimeEntryStatus @default(DRAFT)
  description      String?
  correctionReason String?
  approvedAt       DateTime?       @db.Timestamptz(3)
  approvedById     String?
  deletedAt        DateTime?       @db.Timestamptz(3)
  deletedById      String?
  createdAt        DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  issue        Issue?       @relation(fields: [issueId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([projectId, workDate, status])
  @@index([projectId, userId, workDate])
  @@index([organizationId, status])
  @@map("time_entries")
}

model ProjectCostRecord {
  id                  String           @id @default(cuid())
  organizationId       String
  projectId            String           @unique
  plannedPersonDays    Decimal          @db.Decimal(10, 2)
  standardHoursPerDay  Decimal          @default(8) @db.Decimal(5, 2)
  status               CostRecordStatus @default(ACTIVE)
  notes                String?
  createdById          String
  updatedById          String
  deletedAt            DateTime?        @db.Timestamptz(3)
  deletedById          String?
  createdAt            DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime         @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  createdBy    User         @relation("CostRecordCreator", fields: [createdById], references: [id])
  updatedBy    User         @relation("CostRecordUpdater", fields: [updatedById], references: [id])
  deletedBy    User?        @relation("CostRecordDeleter", fields: [deletedById], references: [id])

  @@index([organizationId, status])
  @@map("project_cost_records")
}

model Session {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  tokenHash      String
  expiresAt      DateTime  @db.Timestamptz(3)
  revokedAt      DateTime? @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([organizationId, userId, revokedAt])
  @@map("sessions")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  action         String
  entityType     String
  entityId       String
  data           Json?
  requestId      String?
  createdAt      DateTime @default(now()) @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User         @relation(fields: [actorId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
